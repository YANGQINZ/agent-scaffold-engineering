    serverChannel.pipeline().addLast(new MyBusinessHandler()); // ← 运行时忽略！MyBusinessHandler 不会被调用！
});

// ✅ 正确：所有业务逻辑必须放在 childHandler 中（由 workerGroup 执行）
b.childHandler(new ChannelInitializer<SocketChannel>() {
    @Override
    protected void initChannel(SocketChannel ch) {
        ch.pipeline()
            .addLast(new LengthFieldBasedFrameDecoder(...))
            .addLast(new ProtobufDecoder(...))
            .addLast(new YourBusinessHandler()); // ← 这里才生效
    }
});
```

